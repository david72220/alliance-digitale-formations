---
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/accompagnement/', label: 'Accompagnement' },
  { href: '/formations/', label: 'Formations' },
  { href: '/ressources/', label: 'Ressources' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 w-full z-50">
  <div class="relative mx-auto max-w-7xl px-4 pt-4 pb-8">
    <nav class="relief-panel flex items-center justify-between px-5 py-3" aria-label="Menu principal">
      <a href="/" class="relative z-10 flex items-center">
        <span class="bg-white/95 rounded-lg px-3 py-1.5 shadow-md">
          <img src="/images/logo-alliance.png" alt="Alliance Digitale" class="h-10 w-auto object-contain" />
        </span>
      </a>
      <div class="relative z-10 hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a href={link.href} class="px-3 py-2 rounded-lg text-sm font-medium text-white/75 hover:text-white hover:bg-white/10 transition">
            {link.label}
          </a>
        ))}
      </div>
      <a href="/contact/" class="btn-primary hidden lg:inline-flex">Prendre rendez-vous</a>
    </nav>
  </div>
</header>

<div class="h-24"></div>
