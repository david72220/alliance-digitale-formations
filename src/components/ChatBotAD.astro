---
// ChatBot Alliance-Digitale — bulle flottante + fenêtre de chat
// Utilise l'API demo-api.srv1179315.hstgr.cloud avec le prompt "alliance"
---

<div id="ad-chatbot" class="fixed bottom-6 right-6 z-50">
  <!-- Bulle -->
  <button
    id="ad-chat-toggle"
    class="w-14 h-14 rounded-full shadow-lg flex items-center justify-center transition-all hover:scale-105"
    style="background:linear-gradient(135deg,#3B97D3 0%,#22D3EE 100%);box-shadow:0 4px 20px rgba(59,151,211,0.4);"
    aria-label="Ouvrir le chat"
  >
    <svg id="ad-chat-icon-open" class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <svg id="ad-chat-icon-close" class="hidden w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Fenêtre -->
  <div id="ad-chat-window" class="hidden absolute bottom-20 right-0 w-80 sm:w-96 rounded-2xl shadow-2xl overflow-hidden flex flex-col"
    style="background:#0B1120;border:1px solid rgba(59,151,211,0.2);max-height:520px;">
    
    <!-- Header -->
    <div class="px-4 py-3 flex items-center gap-3" style="background:rgba(59,151,211,0.1);border-bottom:1px solid rgba(59,151,211,0.15);">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background:linear-gradient(135deg,#3B97D3 0%,#22D3EE 100%);">
        <span class="text-white font-bold text-sm">AD</span>
      </div>
      <div class="flex-1">
        <div class="text-white font-semibold text-sm">Assistant Alliance Digitale</div>
        <div class="text-white/50 text-xs flex items-center gap-1">
          <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
          En ligne
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div id="ad-chat-messages" class="flex-1 overflow-y-auto px-4 py-4 space-y-3" style="max-height:320px;">
      <div class="flex justify-start">
        <div class="rounded-2xl rounded-tl-sm px-4 py-2 max-w-[85%] text-sm" style="background:rgba(59,151,211,0.1);color:#E2E8F0;">
          Bonjour ! Je suis l'assistant d'Alliance Digitale. Comment puis-je vous aider ? Site web, formation IA, automatisation ?
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="px-4 py-3 border-t" style="border-color:rgba(59,151,211,0.15);">
      <div class="flex gap-2">
        <input
          id="ad-chat-input"
          type="text"
          placeholder="Votre message..."
          class="flex-1 rounded-lg px-3 py-2 text-sm bg-white/5 text-white placeholder-white/30 border focus:outline-none"
          style="border-color:rgba(59,151,211,0.2);"
        />
        <button
          id="ad-chat-send"
          class="rounded-lg px-3 py-2 text-sm font-medium text-white transition hover:opacity-90"
          style="background:linear-gradient(135deg,#3B97D3 0%,#22D3EE 100%);"
        >
          →
        </button>
      </div>
      <div class="text-white/30 text-[10px] mt-2 text-center">
        Assistant IA • Réponses automatiques • Alliance Digitale
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const API_BASE = "https://demo-api.srv1179315.hstgr.cloud";
  const toggle = document.getElementById('ad-chat-toggle');
  const window_el = document.getElementById('ad-chat-window');
  const iconOpen = document.getElementById('ad-chat-icon-open');
  const iconClose = document.getElementById('ad-chat-icon-close');
  const messages = document.getElementById('ad-chat-messages');
  const input = document.getElementById('ad-chat-input');
  const sendBtn = document.getElementById('ad-chat-send');
  
  let sessionId = null;
  let isOpen = false;

  // Charger la session depuis localStorage
  try {
    const saved = localStorage.getItem('ad_chatbot_session');
    if (saved) {
      const data = JSON.parse(saved);
      if (data.session_id && data.expires_at > Date.now() / 1000) {
        sessionId = data.session_id;
      }
    }
  } catch(e) {}

  // Toggle
  toggle.addEventListener('click', () => {
    isOpen = !isOpen;
    window_el.classList.toggle('hidden', !isOpen);
    iconOpen.classList.toggle('hidden', isOpen);
    iconClose.classList.toggle('hidden', !isOpen);
    if (isOpen) input.focus();
  });

  // Démarrer une session auto si pas de session
  async function ensureSession() {
    if (sessionId) return true;
    try {
      const res = await fetch(API_BASE + '/api/demo/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: 'visitor@alliance-digitale.fr', metier: 'alliance' }),
      });
      if (!res.ok) return false;
      const data = await res.json();
      if (data.session_id) {
        sessionId = data.session_id;
        localStorage.setItem('ad_chatbot_session', JSON.stringify({
          session_id: sessionId,
          expires_at: data.expires_at || (Date.now() / 1000 + 7 * 86400),
        }));
        return true;
      }
    } catch(e) {}
    return false;
  }

  // Ajouter un message
  function addMessage(text, isUser) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex ' + (isUser ? 'justify-end' : 'justify-start');
    const bubble = document.createElement('div');
    bubble.className = 'rounded-2xl px-4 py-2 max-w-[85%] text-sm';
    if (isUser) {
      bubble.style.background = 'linear-gradient(135deg,#3B97D3 0%,#22D3EE 100%)';
      bubble.style.color = '#fff';
      bubble.classList.add('rounded-tr-sm');
    } else {
      bubble.style.background = 'rgba(59,151,211,0.1)';
      bubble.style.color = '#E2E8F0';
      bubble.classList.add('rounded-tl-sm');
    }
    bubble.textContent = text;
    wrapper.appendChild(bubble);
    messages.appendChild(wrapper);
    messages.scrollTop = messages.scrollHeight;
  }

  // Indicateur de frappe
  function showTyping() {
    const wrapper = document.createElement('div');
    wrapper.id = 'ad-typing';
    wrapper.className = 'flex justify-start';
    wrapper.innerHTML = '<div class="rounded-2xl rounded-tl-sm px-4 py-3 text-sm" style="background:rgba(59,151,211,0.1);color:#E2E8F0;"><span class="animate-pulse">●●●</span></div>';
    messages.appendChild(wrapper);
    messages.scrollTop = messages.scrollHeight;
  }
  function hideTyping() {
    const t = document.getElementById('ad-typing');
    if (t) t.remove();
  }

  // Envoyer un message
  async function sendMessage() {
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    addMessage(text, true);
    showTyping();

    const ok = await ensureSession();
    if (!ok) {
      hideTyping();
      addMessage("Désolé, je ne peux pas répondre pour le moment. Contactez-nous à contact@alliance-digitale.fr ou au 02 43 00 00 00.", false);
      return;
    }

    try {
      const res = await fetch(API_BASE + '/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: sessionId, message: text }),
      });
      hideTyping();
      if (!res.ok) {
        addMessage("Désolé, une erreur est survenue. Contactez-nous à contact@alliance-digitale.fr.", false);
        return;
      }
      const data = await res.json();
      addMessage(data.reply || "Désolé, je n'ai pas compris. Pouvez-vous reformuler ?", false);
    } catch(e) {
      hideTyping();
      addMessage("Le serveur ne répond pas pour le moment. Contactez-nous à contact@alliance-digitale.fr ou au 02 43 00 00 00.", false);
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendMessage();
  });
})();
</script>