---
import type { Formation } from '../lib/notion.ts';

export interface Props {
  formation: Formation;
}

const { formation } = Astro.props;
---

<a
  href={`/formations/${formation.slug}/`}
  class="relief-panel relief-1 fiber-pulse fiber-pulse--slow group block relative overflow-hidden rounded-2xl transition-all duration-300"
>
  <div class="relative z-10 h-48 overflow-hidden">
    {formation.photo ? (
      <img
        src={formation.photo}
        alt={formation.title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : formation.image ? (
      <img
        src={formation.image}
        alt={formation.title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-alliance-blue/30 to-alliance-orange/30"></div>
    )}
  </div>
  
  <div class="relative z-10 p-6">
    <h3 class="font-display text-xl font-bold text-white mb-2 group-hover:text-alliance-blue transition-colors">
      {formation.title}
    </h3>
    
    {formation.subtitle && (
      <p class="text-sm text-alliance-orange font-medium mb-3">{formation.subtitle}</p>
    )}
    
    <p class="text-sm text-white/60 leading-relaxed line-clamp-3 mb-4">
      {formation.generalObjective || formation.description}
    </p>
    
    <div class="flex items-center justify-between text-xs text-white/40">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {formation.duration}
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.934 12.935a4 4 0 010-5.686l.001-.001a4 4 0 015.657 0l.001.001a4 4 0 010 5.686zM15.001 15l-1.424 1.424a4 4 0 01-5.657 0l-.001-.001a4 4 0 010-5.686l.001-.001a4 4 0 015.657 0L15 11.999M15.001 15l-1.425-1.425"/>
        </svg>
        {formation.format}
      </span>
    </div>

    <div class="mt-4">
      <p class="text-sm font-semibold text-alliance-orange leading-snug">
        {formation.priceText || (formation.price ? `${formation.price.toLocaleString('fr-FR')} € HT` : 'Tarif sur demande')}
      </p>
      <span class="mt-2 inline-flex items-center gap-1 px-2 py-1 rounded-full bg-alliance-blue/15 text-alliance-blue text-[10px] font-semibold uppercase tracking-wide whitespace-nowrap">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        OPCO sur demande
      </span>
    </div>
  </div>
</a>

