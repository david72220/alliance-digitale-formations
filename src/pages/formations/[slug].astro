---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getFormations } from '../../lib/notion.ts';

export async function getStaticPaths() {
  const formations = await getFormations();
  return formations.map((formation) => ({
    params: { slug: formation.slug },
    props: { formation },
  }));
}

const { formation } = Astro.props;

const courseLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": formation.title,
  "description": formation.generalObjective || `Formation ${formation.title} par Alliance Digitale`,
  "provider": {
    "@type": "Organization",
    "name": "Alliance Digitale",
    "sameAs": Astro.site!.toString().replace(/\/$/, '')
  },
  "url": new URL(Astro.url.pathname, Astro.site).toString(),
  ...(formation.price && { "offers": { "@type": "Offer", "price": String(formation.price), "priceCurrency": "EUR", "category": "Formation professionnelle" } }),
  ...(formation.duration && { "timeRequired": formation.duration }),
  ...(formation.audience && { "audience": { "@type": "EducationalAudience", "audienceType": formation.audience } }),
  "inLanguage": "fr-FR",
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "onsite",
    "courseWorkload": formation.duration || "PT7H"
  }
};
---

<Layout
  title={`${formation.title} — Alliance Digitale`}
  description={formation.generalObjective}
  jsonLd={courseLd}
>
  <Header />

  <main class="flex-1">
    <section class="pt-36 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="mb-8">
          <a href="/formations/" class="text-sm text-white/50 hover:text-alliance-blue transition">← Retour aux formations</a>
        </div>

        <div class="mb-10">
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-3">Formation</p>

          <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white mb-4">{formation.title}</h1>

          {formation.generalObjective && (
            <p class="text-alliance-orange text-lg font-medium">{formation.generalObjective}</p>
          )}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
          <div class="p-4 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Durée</p>
            <p class="text-white font-semibold">{formation.duration || '—'}</p>
          </div>
          <div class="p-4 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Public</p>
            <p class="text-white font-semibold">{formation.audience || '—'}</p>
          </div>
          <div class="p-4 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Méthodes</p>
            <p class="text-white font-semibold">{formation.methods || '—'}</p>
          </div>
          <div class="p-4 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Tarif</p>
            <p class="text-white font-semibold">{formation.price ? `${formation.price} € HT` : 'Sur demande'}</p>
          </div>
        </div>

        {formation.photo ? (
          <div class="mb-10 rounded-2xl overflow-hidden">
            <img src={formation.photo} alt={formation.title} loading="eager" fetchpriority="high" decoding="async" class="w-full h-64 sm:h-80 object-cover" />
          </div>
        ) : formation.image ? (
          <div class="mb-10 rounded-2xl overflow-hidden">
            <img src={formation.image} alt={formation.title} loading="eager" fetchpriority="high" decoding="async" class="w-full h-64 sm:h-80 object-cover" />
          </div>
        ) : null}

        <div class="prose prose-invert max-w-none space-y-8">
          {formation.program && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Programme détaillé</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.program}</p>
            </div>
          )}

          {formation.outcomes && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Résultats attendus</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.outcomes}</p>
            </div>
          )}

          {formation.competencies && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Compétences visées</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.competencies}</p>
            </div>
          )}

          {formation.schedule && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Déroulé</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.schedule}</p>
            </div>
          )}

          {formation.materials && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Supports de cours</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.materials}</p>
            </div>
          )}

          {formation.evaluationTools && (
            <div>
              <h2 class="text-2xl font-bold text-white mb-3">Outils d'évaluation</h2>
              <p class="text-white/70 whitespace-pre-line">{formation.evaluationTools}</p>
            </div>
          )}
        </div>

        {formation.fundingActive && (
          <div class="mt-10 p-6 rounded-xl border border-alliance-blue/30 bg-alliance-blue/10">
            <p class="text-sm text-alliance-blue font-semibold mb-2">Financement possible</p>
            <p class="text-white/80">Cette formation est éligible au financement OPCO pour les entreprises avec salariés, dans le cadre de notre partenariat Signe+.</p>
          </div>
        )}

        <div class="mt-12">
          <a href="/contact/" class="btn-primary text-base px-8 py-4">Demander un devis / Prendre RDV</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
