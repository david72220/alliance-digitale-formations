---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FiberFrame from '../../components/FiberFrame.astro';

const title = 'Formation Essentiel Solo — Qonto + Indy — Alliance Digitale';
const description = 'Prendre en main sa gestion commerciale avec Qonto et Indy. Formation individuelle de 1h, comprise dans la prestation Palier 2. Autonomie opérationnelle dès J+1.';
const canonical = 'https://www.alliance-digitale.fr/formations/f-a-essentiel-solo/';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Course',
    name: 'Formation Essentiel Solo — Qonto + Indy',
    description,
    provider: { '@type': 'Organization', name: 'Alliance Digitale', url: 'https://www.alliance-digitale.fr' },
    coursePrerequisites: 'Savoir naviguer sur un site web, notions basiques de TVA, connaître son SIRET et régime fiscal',
    educationalLevel: 'Beginner',
    inLanguage: 'fr-FR',
    offers: [
      { '@type': 'Offer', price: '0', priceCurrency: 'EUR', description: 'Inclus dans la prestation Palier 2 (490 € HT globale)', availability: 'https://schema.org/InStock' },
    ],
    timeRequired: 'PT1H',
    courseCode: 'F-A',
  },
];

const calendarUrl = 'https://cal.eu/alliance-digitale/decouverte-30-min';
---

<Layout title={title} description={description} image="/og-image.png" jsonLd={jsonLd}>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="relative pt-36 pb-20 px-4 sm:px-6 lg:px-8 bg-[#0F2942] text-white overflow-hidden">
      <FiberFrame client:load />
      <div class="relative z-10 max-w-4xl mx-auto">
        <div class="inline-block mb-4 px-4 py-1.5 bg-[#3b97d3] rounded-full text-sm font-semibold tracking-wide">Stack A — Essentiel Solo</div>
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4" style="font-family: 'Playfair Display', serif;">Prendre en main sa gestion commerciale avec Qonto et Indy</h1>
        <p class="text-lg text-white/80 mb-6">1 heure · Visio partagée · Individuel · <strong class="text-white">Compris dans la prestation Palier 2</strong></p>
        <div class="flex flex-wrap gap-4">
          <a href="/audit/" class="inline-flex items-center px-6 py-3 bg-[#A63D40] hover:bg-[#9E2114] text-white font-semibold rounded-lg transition">Passer le diagnostic gratuit →</a>
          <a href={calendarUrl} target="_blank" rel="noopener" class="inline-flex items-center px-6 py-3 border border-white/30 hover:bg-white/10 text-white font-semibold rounded-lg transition">Réserver un entretien</a>
        </div>
      </div>
    </section>

    <!-- Public visé -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#FEFCF8]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-4" style="font-family: 'Playfair Display', serif;">Public visé</h2>
        <p class="text-[#1A2332] leading-relaxed">Dirigeant solo de très petite entreprise (freelance, consultant, coach, artisan solo, profession libérale) réalisant moins de 30 factures par mois, sans expert-comptable ou avec un expert-comptable acceptant le format numérique standard (FEC).</p>
      </div>
    </section>

    <!-- Objectifs pédagogiques -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-6" style="font-family: 'Playfair Display', serif;">Objectifs pédagogiques</h2>
        <p class="text-[#5B6472] mb-6">À l'issue de la formation, le stagiaire sera capable de :</p>
        <ol class="space-y-3 text-[#1A2332]">
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">1</span><span><strong>Créer</strong> un devis conforme aux mentions légales 2026 sur Qonto en moins de 3 minutes</span></li>
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">2</span><span><strong>Transformer</strong> un devis accepté en facture sans ressaisie</span></li>
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">3</span><span><strong>Recevoir</strong> une facture électronique de fournisseur via l'annuaire PA</span></li>
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">4</span><span><strong>Suivre</strong> ses encaissements et sa trésorerie en temps réel</span></li>
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">5</span><span><strong>Exporter</strong> son FEC et sa déclaration TVA depuis Indy</span></li>
          <li class="flex gap-3"><span class="flex-shrink-0 w-7 h-7 rounded-full bg-[#3b97d3] text-white text-sm font-bold flex items-center justify-center">6</span><span><strong>Identifier</strong> les obligations réglementaires facturation électronique 2026-2027 et son propre calendrier</span></li>
        </ol>
      </div>
    </section>

    <!-- Programme détaillé -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#FEFCF8]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-6" style="font-family: 'Playfair Display', serif;">Programme détaillé (60 minutes)</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-[#0F2942] text-white">
                <th class="px-4 py-3 rounded-tl-lg">Créneau</th>
                <th class="px-4 py-3">Durée</th>
                <th class="px-4 py-3">Contenu</th>
                <th class="px-4 py-3 rounded-tr-lg">Modalité</th>
              </tr>
            </thead>
            <tbody class="text-[#1A2332]">
              <tr class="border-b border-[#F0F1F3]"><td class="px-4 py-3">0-5 min</td><td class="px-4 py-3">5'</td><td class="px-4 py-3">Tour de table, rappel des objectifs, positionnement</td><td class="px-4 py-3">Échange</td></tr>
              <tr class="border-b border-[#F0F1F3] bg-white/50"><td class="px-4 py-3">5-15 min</td><td class="px-4 py-3">10'</td><td class="px-4 py-3">Configuration Qonto : profil entreprise, mentions légales 2026, personnalisation logo, numérotation</td><td class="px-4 py-3">Démo + reproduction</td></tr>
              <tr class="border-b border-[#F0F1F3]"><td class="px-4 py-3">15-30 min</td><td class="px-4 py-3">15'</td><td class="px-4 py-3">Cycle complet devis → facture : création d'un devis-type, envoi client, conversion, envoi facture</td><td class="px-4 py-3">Cas pratique avec vraie donnée</td></tr>
              <tr class="border-b border-[#F0F1F3] bg-white/50"><td class="px-4 py-3">30-40 min</td><td class="px-4 py-3">10'</td><td class="px-4 py-3">Réception facture électronique : configuration annuaire PA, réception, validation, archivage</td><td class="px-4 py-3">Démonstration</td></tr>
              <tr class="border-b border-[#F0F1F3]"><td class="px-4 py-3">40-50 min</td><td class="px-4 py-3">10'</td><td class="px-4 py-3">Indy — synchronisation bancaire, catégorisation, préparation TVA</td><td class="px-4 py-3">Démo + mise en pratique</td></tr>
              <tr class="bg-white/50"><td class="px-4 py-3">50-60 min</td><td class="px-4 py-3">10'</td><td class="px-4 py-3">Récap, questions, remise du livret, points de vigilance conformité 09/2026 et 09/2027</td><td class="px-4 py-3">Échange</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Ce que vous saurez faire -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-6" style="font-family: 'Playfair Display', serif;">Ce que vous saurez faire</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-[#0F2942] mb-2">Sur Qonto</h3>
            <ul class="space-y-1.5 text-[#1A2332] text-sm">
              <li>✓ Créer un devis PDF conforme mentions légales 2026 en 3 minutes</li>
              <li>✓ Personnaliser un modèle de facture (logo, couleurs, conditions de règlement)</li>
              <li>✓ Numéroter automatiquement vos factures (séquence continue)</li>
              <li>✓ Recevoir une facture électronique via l'annuaire des Plateformes Agréées</li>
              <li>✓ Distinguer une facture électronique conforme d'un simple PDF</li>
              <li>✓ Suivre les statuts de vos factures émises (envoyée / vue / payée / en retard)</li>
              <li>✓ Envoyer une relance simple à un client en retard</li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-[#0F2942] mb-2">Sur Indy</h3>
            <ul class="space-y-1.5 text-[#1A2332] text-sm">
              <li>✓ Consulter votre trésorerie disponible en temps réel</li>
              <li>✓ Catégoriser automatiquement une dépense bancaire</li>
              <li>✓ Attacher un justificatif photo à une dépense via mobile</li>
              <li>✓ Générer votre déclaration TVA depuis Indy</li>
              <li>✓ Exporter votre FEC pour l'expert-comptable ou un contrôle</li>
              <li>✓ Émettre une note de frais mobile depuis votre smartphone</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Tarifs -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#0F2942] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold mb-4" style="font-family: 'Playfair Display', serif;">Tarif</h2>
        <div class="inline-block bg-white/10 rounded-2xl p-8">
          <p class="text-4xl font-bold mb-2">Inclus dans Palier 2</p>
          <p class="text-white/70">Prestation complète à 490 € HT · Formation de 1h en visio individuelle</p>
        </div>
        <p class="text-white/60 text-sm mt-4">Frais de déplacement inclus dans un rayon de 100 km autour d'Ecommoy (72220).</p>
      </div>
    </section>

    <!-- Livrables -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#FEFCF8]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-6" style="font-family: 'Playfair Display', serif;">Livrables remis au stagiaire</h2>
        <ul class="space-y-2 text-[#1A2332]">
          <li class="flex gap-2"><span class="text-[#A63D40]">▸</span> Livret utilisateur personnalisé PDF (6-8 pages)</li>
          <li class="flex gap-2"><span class="text-[#A63D40]">▸</span> Accès Notion "Fiches réflexe Qonto + Indy"</li>
          <li class="flex gap-2"><span class="text-[#A63D40]">▸</span> 3 vidéos courtes (2-3 min) : créer un devis, recevoir une facture électronique, déclarer sa TVA</li>
          <li class="flex gap-2"><span class="text-[#A63D40]">▸</span> Certificat d'assiduité</li>
        </ul>
      </div>
    </section>

    <!-- Évaluation finale -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl font-bold text-[#0F2942] mb-4" style="font-family: 'Playfair Display', serif;">Évaluation finale</h2>
        <p class="text-[#1A2332]">Le stagiaire doit réaliser en autonomie en 15 minutes : création d'un devis, conversion en facture, ajout d'une dépense avec justificatif, consultation du tableau de bord trésorerie. <strong>Réussite = 4 tâches sur 4</strong> accomplies sans intervention du formateur.</p>
      </div>
    </section>

    <!-- Prérequis & Accessibilité -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#FEFCF8]">
      <div class="max-w-4xl mx-auto grid sm:grid-cols-2 gap-8">
        <div>
          <h2 class="text-xl font-bold text-[#0F2942] mb-4" style="font-family: 'Playfair Display', serif;">Prérequis techniques</h2>
          <ul class="space-y-1.5 text-sm text-[#1A2332]">
            <li>✓ Savoir naviguer sur un site web et manipuler une adresse email</li>
            <li>✓ Comprendre les notions basiques de TVA (assujetti ou non, taux normal)</li>
            <li>✓ Connaître son SIRET, code APE et régime fiscal (BIC/BNC, réel simplifié ou micro)</li>
          </ul>
        </div>
        <div>
          <h2 class="text-xl font-bold text-[#0F2942] mb-4" style="font-family: 'Playfair Display', serif;">Accessibilité handicap</h2>
          <p class="text-sm text-[#1A2332]">Alliance Digitale s'engage à rendre ses formations accessibles à tous. Référent handicap : David Pierre Olivier — <a href="mailto:contact@alliance-digitale.fr" class="text-[#3b97d3] hover:underline">contact@alliance-digitale.fr</a>. Adaptation possible du format, du rythme et des supports selon le besoin déclaré.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-[#0F2942] text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold mb-4" style="font-family: 'Playfair Display', serif;">Prêt à être autonome sur votre gestion commerciale ?</h2>
        <p class="text-white/80 mb-8">Passez le diagnostic gratuit en 8 questions et découvrez quelle stack est faite pour vous.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/audit/" class="inline-flex items-center px-8 py-4 bg-[#A63D40] hover:bg-[#9E2114] text-white font-semibold rounded-lg transition text-lg">Passer le diagnostic gratuit →</a>
          <a href={calendarUrl} target="_blank" rel="noopener" class="inline-flex items-center px-8 py-4 border border-white/30 hover:bg-white/10 text-white font-semibold rounded-lg transition text-lg">Réserver un entretien</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  table th, table td { font-size: 0.875rem; }
</style>