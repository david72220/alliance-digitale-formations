---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Page de capture systeme.io — le tunnel mail et les pages de formation
// sont déjà configurés côté systeme.io. Le bouton d'inscription redirige vers cette URL.
const INSCRIPTION_URL = 'https://alliance-digitale.systeme.io/starterpack-2-0-def0ca04-5c8fa367-10504e4a-f2795594';

const days = [
  {
    n: 1,
    titre: 'Cartographier vos tâches répétitives',
    desc: "Identifiez les 5 tâches qui vous coûtent le plus de temps chaque semaine. Méthode simple, template fourni.",
    livrable: 'Grille d\'audit personnalisée',
  },
  {
    n: 2,
    titre: 'Premier prompt IA qui marche vraiment',
    desc: "Rédigez un prompt professionnel adapté à votre métier. On corrige ensemble les erreurs classiques et on obtient un résultat utilisable.",
    livrable: 'Bibliothèque de prompts par cas d\'usage',
  },
  {
    n: 3,
    titre: 'Automatiser une relance client',
    desc: "Mettez en place une séquence de relance automatique (email + rappel) sans rien coder. On utilise un outil gratuit accessible à toutes les PME.",
    livrable: 'Scénario de relance opérationnel',
  },
  {
    n: 4,
    titre: 'Générer un visuel pro en 2 minutes',
    desc: "Créez un visuel pour vos réseaux sociaux, un prospectus ou un slide de présentation sans outil complexe ni compétence graphique.",
    livrable: 'Visuel prêt à publier',
  },
  {
    n: 5,
    titre: 'Votre plan d\'action 30 jours',
    desc: "Synthèse de la semaine + plan d'action priorisé pour les 30 prochains jours. On identifie le premier projet à automatiser et le ROI estimé.",
    livrable: 'Plan d\'action chiffré',
  },
];
---

<Layout
  title="Challenge IA gratuit 5 jours PME | Alliance Digitale"
  description="Inscrivez-vous gratuitement au challenge 5 jours d'Alliance Digitale : un email par jour, des actions concrètes, des outils gratuits. Pour les PME et dirigeants de Sarthe."
  noindex={false}
>
  <Header />

  <main class="flex-1">
    <!-- HERO -->
    <section class="relative overflow-hidden bg-alliance-dark-2 pt-32 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
      <div class="relative max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-alliance-red/30 bg-alliance-red/10 text-alliance-red text-xs font-semibold uppercase tracking-wider mb-6" data-hero-anim="badge">
          Challenge gratuit · 5 jours
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight" data-hero-anim="title">
          <span class="hero-line">Boostez votre productivité</span>
          <span class="gradient-text hero-line">avec l'IA en 5 jours</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/70 max-w-2xl mx-auto mb-8 leading-relaxed" data-hero-anim="lead">
          Un email par jour pendant 5 jours. Chaque jour, une action concrète à mener
          dans votre PME avec un outil gratuit. À la fin de la semaine, vous avez
          automatisé votre première tâche et gagné plusieurs heures par semaine.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-white/65" data-hero-anim="stats">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            5 emails actionnables
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            30 min par jour
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            100% gratuit
          </span>
        </div>
      </div>
    </section>

    <!-- DÉROULÉ 5 JOURS -->
    <section class="py-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14" data-reveal>
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-3">Le programme</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
            5 jours, 5 actions concrètes
          </h2>
          <p class="text-white/60 max-w-2xl mx-auto">
            Chaque email contient une action à réaliser immédiatement, un outil gratuit
            à mettre en place, et un livrable pour votre entreprise.
          </p>
        </div>

        <div class="space-y-4">
          {days.map((day, i) => (
            <div class="relief-panel p-6 sm:p-8" data-reveal data-reveal-delay={String(i * 0.06)}>
              <div class="flex flex-col sm:flex-row gap-6">
                <div class="shrink-0">
                  <div class="w-14 h-14 rounded-2xl bg-alliance-blue/15 border border-alliance-blue/30 flex items-center justify-center">
                    <span class="font-display text-2xl font-bold text-alliance-blue">J{day.n}</span>
                  </div>
                </div>
                <div class="flex-1">
                  <h3 class="font-display text-xl font-bold text-white mb-2">{day.titre}</h3>
                  <p class="text-white/70 leading-relaxed mb-3">{day.desc}</p>
                  <div class="inline-flex items-center gap-2 text-sm text-alliance-red">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                    Livrable : {day.livrable}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- POUR QUI -->
    <section class="py-20 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <p class="text-alliance-red text-sm font-bold uppercase tracking-widest mb-3">Pour qui</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4">
            Conçu pour les PME qui manquent de temps
          </h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-6">
          <div class="relief-panel p-6 text-center" data-reveal data-reveal-delay="0">
            <p class="font-display text-lg font-bold text-white mb-2">Dirigeants</p>
            <p class="text-white/60 text-sm">Repérez où l'IA peut vraiment vous faire gagner du temps, sans investissement lourd.</p>
          </div>
          <div class="relief-panel p-6 text-center" data-reveal data-reveal-delay="0.08">
            <p class="font-display text-lg font-bold text-white mb-2">Salariés</p>
            <p class="text-white/60 text-sm">Apprenez à utiliser l'IA au quotidien sur vos vraies tâches, pas sur des exemples théoriques.</p>
          </div>
          <div class="relief-panel p-6 text-center" data-reveal data-reveal-delay="0.16">
            <p class="font-display text-lg font-bold text-white mb-2">Auto-entrepreneurs</p>
            <p class="text-white/60 text-sm">Automatisez les tâches administratives qui vous empêchent de vous concentrer sur vos clients.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- INSCRIPTION (redirection vers systeme.io) -->
    <section class="py-20 px-4 sm:px-6 lg:px-8" id="inscription">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-10" data-reveal>
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-3">Inscription</p>
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-4">
            Je m'inscris gratuitement
          </h2>
          <p class="text-white/60">
            30 minutes par jour pendant 5 jours. Aucun spam, désinscription en un clic.
          </p>
        </div>

        <div class="relief-panel p-8 sm:p-10 text-center" data-reveal data-reveal-delay="0.1">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-alliance-blue/15 border border-alliance-blue/30 flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-3">
            Recevez le premier email dès demain matin
          </h3>
          <p class="text-white/60 mb-8 leading-relaxed">
            Cliquez sur le bouton ci-dessous pour accéder au formulaire d'inscription.
            La campagne email se met en place automatiquement — vous recevrez
            un email par jour pendant 5 jours, avec une action concrète et un livrable
            pour votre entreprise.
          </p>

          <a href={INSCRIPTION_URL} class="btn-primary text-base px-8 py-4 inline-flex items-center gap-2" target="_blank" rel="noopener noreferrer">
            Je démarre le challenge gratuit
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>

          <p class="text-xs text-white/65 mt-6">
            Inscription sécurisée via systeme.io · RGPD respecté · Vos données ne sont jamais revendues
          </p>
        </div>

        <p class="text-center text-sm text-white/65 mt-8">
          <a href="/" class="hover:text-white/60 transition">← Retour à l'accueil</a>
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>