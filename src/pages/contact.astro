---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const calendlyUrl = "https://cal.eu/alliance-digitale/decouverte-30-min";
---

<Layout
  title="Contact — Alliance Digitale"
  description="Prenez rendez-vous avec Alliance Digitale pour discuter de votre accompagnement IA ou d'une formation pour vos salariés."
>
  <Header />

  <main class="flex-1">
    <section class="pt-36 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12" data-reveal>
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-3">Contact</p>

          <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white mb-6">Prenons rendez-vous</h1>
          
          <p class="text-white/60 max-w-2xl mx-auto">
            Choisissez un créneau de 30 minutes. On fera le point sur vos enjeux IA, votre conformité AI Act
            et les premières actions possibles.
          </p>
        </div>
        
        <div class="relief-panel p-4 sm:p-8" data-reveal data-reveal-delay="0.1">
          <div id="cal-mount" data-cal-url={calendlyUrl} class="min-h-[700px] flex items-center justify-center">
            <button id="cal-load-btn" type="button" class="btn-primary text-base px-8 py-4">
              Afficher le calendrier de prise de rendez-vous
            </button>
            <noscript>
              <iframe src={calendlyUrl} width="100%" height="700" loading="lazy" frameborder="0" class="rounded-xl" title="Prise de rendez-vous Alliance Digitale"></iframe>
            </noscript>
          </div>
        </div>

        <p class="text-center text-xs text-white/65 mt-4">
          Le calendrier est fourni par Cal.eu et déposera des cookies tiers nécessaires à son fonctionnement.
        </p>

        <script>
          const mount = document.getElementById('cal-mount');
          const btn = document.getElementById('cal-load-btn');
          const url = mount?.dataset.calUrl;
          btn?.addEventListener('click', () => {
            if (!mount || !url) return;
            mount.innerHTML = `<iframe src="${url}" width="100%" height="700" loading="lazy" frameborder="0" class="rounded-xl" title="Prise de rendez-vous Alliance Digitale"></iframe>`;
          });
        </script>
        
        <div class="mt-12 grid sm:grid-cols-2 gap-6 text-center">
          <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-sm text-white/65 mb-1">E-mail</p>
            <a href="mailto:contact@alliance-digitale.fr" class="text-white hover:text-alliance-blue transition">contact@alliance-digitale.fr</a>
          </div>
          
          <div class="p-6 rounded-xl border border-white/10 bg-white/[0.03]">
            <p class="text-sm text-white/65 mb-1">Téléphone</p>
            <a href="tel:+336****3489" class="text-white hover:text-alliance-blue transition">06 86 94 34 89</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
