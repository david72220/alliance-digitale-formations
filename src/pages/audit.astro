---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MatriceAudit from '../components/MatriceAudit.tsx';
import FiberFrame from '../components/FiberFrame.astro';

const title = 'Audit gestion commerciale TPE — Alliance Digitale';
const description = 'Diagnostic gratuit en 8 questions et 2 minutes pour découvrir votre stack logiciel idéal : Qonto, Pennylane, Axonaut, Obat/Trustup Pro. Recevez un rapport PDF détaillé et réservez un entretien de qualification.';
const canonical = 'https://www.alliance-digitale.fr/audit/';
const image = '/og-image.png';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonical,
    image: `${Astro.site}${image}`.replace(/\/+$/, '').replace(/\/$/, '') + image,
    inLanguage: 'fr-FR',
    isPartOf: { '@type': 'WebSite', url: Astro.site?.toString().replace(/\/$/, '') },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Audit gestion commerciale TPE',
    provider: { '@type': 'Organization', name: 'Alliance Digitale' },
    description:
      'Diagnostic gratuit en ligne : 8 questions pour identifier le stack logiciel adapté (comptabilité, facturation électronique, CRM, BTP) et recevoir un rapport PDF personnalisé.',
    url: canonical,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
    },
    areaServed: { '@type': 'AdministrativeArea', name: 'Sarthe' },
  },
];

const apiEndpoint = 'https://n8n.srv1179315.hstgr.cloud/webhook/audit-tpe';
const calendarUrl = 'https://cal.eu/alliance-digitale/decouverte-30-min';
---

<Layout title={title} description={description} image={image} jsonLd={jsonLd}>
  <Header />

  <main class="flex-1">
    <section class="pt-36 pb-12 px-4 sm:px-6 lg:px-8" aria-labelledby="audit-hero-title">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-4" data-hero-anim>Diagnostic outils</p>
        <h1 id="audit-hero-title" class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight" data-hero-anim>
          Diagnostic gratuit
        </h1>
        <p class="text-xl sm:text-2xl text-white/80 mb-4" data-hero-anim>
          8 questions, 2 minutes
        </p>
        <p class="text-white/60 max-w-2xl mx-auto" data-hero-anim>
          Découvrez quel stack logiciel correspond à votre métier, votre volume de factures et votre budget. Recevez un rapport PDF personnalisé et un créneau d'entretien de qualification gratuit.
        </p>
      </div>
    </section>

    <section class="pb-24 px-4 sm:px-6 lg:px-8" aria-label="Audit interactif">
      <div class="max-w-3xl mx-auto">
        <FiberFrame radius={20} speed="normal" class="p-1">
          <div class="bg-[#FEFCF8] rounded-[18px] p-4 sm:p-6">
            <MatriceAudit
              apiEndpoint={apiEndpoint}
              calendarUrl={calendarUrl}
              client:load
            />
          </div>
        </FiberFrame>

        <p class="text-center text-white/50 text-sm mt-6">
          Vos réponses sont transmises via un webhook sécurisé à notre équipe. Aucune donnée bancaire n'est demandée.
        </p>
      </div>
    </section>

    <section class="py-16 px-4 sm:px-6 lg:px-8 bg-alliance-dark-2">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="relief-panel p-6" data-reveal>
          <div class="w-12 h-12 rounded-full bg-alliance-blue/20 text-alliance-blue flex items-center justify-center mx-auto mb-4 text-xl font-bold" aria-hidden="true">1</div>
          <h2 class="font-display text-lg font-semibold text-white mb-2">Répondez à 8 questions</h2>
          <p class="text-white/60 text-sm">Métier, volume, équipe, budget, conformité 2026 : un scoring pédagogique et concret.</p>
        </div>
        <div class="relief-panel p-6" data-reveal data-reveal-delay="0.1">
          <div class="w-12 h-12 rounded-full bg-alliance-blue/20 text-alliance-blue flex items-center justify-center mx-auto mb-4 text-xl font-bold" aria-hidden="true">2</div>
          <h2 class="font-display text-lg font-semibold text-white mb-2">Recevez votre recommandation</h2>
          <p class="text-white/60 text-sm">Stack A, B, C ou BTP avec les outils, le budget mensuel et la formation adaptée.</p>
        </div>
        <div class="relief-panel p-6" data-reveal data-reveal-delay="0.2">
          <div class="w-12 h-12 rounded-full bg-alliance-blue/20 text-alliance-blue flex items-center justify-center mx-auto mb-4 text-xl font-bold" aria-hidden="true">3</div>
          <h2 class="font-display text-lg font-semibold text-white mb-2">Réservez un entretien gratuit</h2>
          <p class="text-white/60 text-sm">30 minutes pour valider le diagnostic, affiner le devis et planifier la mise en œuvre.</p>
        </div>
      </div>
    </section>

    <section class="py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-white mb-6" data-reveal>Quatre stacks adaptés à chaque TPE</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <a href="/formations/f-a-essentiel-solo/" class="relief-panel p-6 text-left hover:-translate-y-2 transition" data-reveal>
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-[#0F2942] text-[#FEFCF8] mb-3">Stack A</span>
            <h3 class="font-display text-lg font-semibold text-white mb-1">Essentiel Solo</h3>
            <p class="text-white/60 text-sm">Qonto + Indy — pour freelance et micro-entrepreneur.</p>
          </a>
          <a href="/formations/f-b-confort-tpe/" class="relief-panel p-6 text-left hover:-translate-y-2 transition" data-reveal data-reveal-delay="0.08">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-[#0F2942] text-[#FEFCF8] mb-3">Stack B</span>
            <h3 class="font-display text-lg font-semibold text-white mb-1">Confort TPE</h3>
            <p class="text-white/60 text-sm">Qonto + Pennylane + Notion — la stack la plus fréquente.</p>
          </a>
          <a href="/formations/f-c-commerciale-integree/" class="relief-panel p-6 text-left hover:-translate-y-2 transition" data-reveal data-reveal-delay="0.16">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-[#0F2942] text-[#FEFCF8] mb-3">Stack C</span>
            <h3 class="font-display text-lg font-semibold text-white mb-1">Commerciale intégrée</h3>
            <p class="text-white/60 text-sm">Axonaut — CRM, devis, facturation et pilotage unifiés.</p>
          </a>
          <a href="/formations/f-btp-artisan-chantier/" class="relief-panel p-6 text-left hover:-translate-y-2 transition" data-reveal data-reveal-delay="0.24">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-[#0F2942] text-[#FEFCF8] mb-3">Stack BTP</span>
            <h3 class="font-display text-lg font-semibold text-white mb-1">Artisan chantier</h3>
            <p class="text-white/60 text-sm">Qonto + Obat/Trustup Pro — devis chantier, factures de situation, rentabilité.</p>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
