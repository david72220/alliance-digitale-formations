---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormationCard from '../components/FormationCard.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import FiberFrame from '../components/FiberFrame.astro';
import heroImage from '../assets/hero-formation-ia.png';
import { getFormations, getCaseStudies, getResources } from '../lib/notion.ts';

const formations = await getFormations();
const studies = await getCaseStudies();
const resources = await getResources();

const heroFormations = formations.slice(0, 3);
const heroStudies = studies.slice(0, 3);
const heroResources = resources.slice(0, 6);

// Sites démo TPE
const tpeDemos = [
  { url: 'https://demo-plombier-ten.vercel.app/', label: 'Plombier', emoji: '🔧', desc: 'Prise de RDV, devis express, suivi chantier' },
  { url: 'https://demo-paysagiste-one.vercel.app/', label: 'Paysagiste', emoji: '🌿', desc: 'Galerie réalisations, devis en ligne, planning' },
  { url: 'https://demo-couvreur.vercel.app/', label: 'Couvreur', emoji: '🏠', desc: 'Portfolio toitures, urgence fuite, devis' },
  { url: 'https://demo-electricien-alpha.vercel.app/', label: 'Électricien', emoji: '⚡', desc: 'Certifications, interventions, devis en ligne' },
];

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que l'accompagnement Alliance Digitale ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un programme en 3 étapes pour les PME en Sarthe : audit de vos usages IA, formation collective de vos salariés, puis mise en place d'une première automatisation concrète et mesurable. Chaque étape produit un livrable : grille d'audit, bibliothèque de prompts, workflow opérationnel."
      }
    },
    {
      "@type": "Question",
      "name": "Je ne connais rien à l'IA, est-ce un problème ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non, c'est même préférable. Nos formations partent de zéro et sont conçues pour des professionnels non-techniques. Chaque session est appliquée à votre métier : vous repartez avec des outils et méthodes immédiatement utilisables."
      }
    },
    {
      "@type": "Question",
      "name": "Quelles entreprises sont concernées ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Toute PME avec salariés en Sarthe et dans les Pays de la Loire : artisans du BTP, commerces, professions libérales, santé, immobilier, restauration, transport… Si vous avez des tâches répétitives, nous pouvons les automatiser."
      }
    },
    {
      "@type": "Question",
      "name": "Qu'est-ce que l'AI Act et pourquoi c'est important pour ma PME ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'AI Act est le règlement européen sur l'IA, applicable à partir d'août 2026. Il impose des obligations aux entreprises qui utilisent des systèmes d'IA, même via ChatGPT. Nous vous aidons à identifier vos risques et à vous mettre en conformité avant l'échéance."
      }
    },
    {
      "@type": "Question",
      "name": "Combien ça coûte ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'audit initial est gratuit (30 min). Les formations sont éligibles aux financements OPCO. L'accompagnement complet est sur devis après l'audit. Le challenge de 5 jours et l'outil de sécurité documentaire sont gratuits."
      }
    }
  ]
};
---

<Layout
  title="Automatisation IA pour PME Sarthe | Alliance Digitale"
  description="Alliance Digitale accompagne les PME en Sarthe : audit IA, formation salariés, automatisation des processus. 23 sessions, 168 apprenants, 95% de satisfaction."
  jsonLd={faqLd}
>
  <Header />

  <main class="flex-1">
    <!-- HERO -->
    <section class="relative overflow-hidden bg-alliance-dark-2 pt-24 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-alliance-blue/10 via-transparent to-transparent"></div>
      <div class="relative max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-alliance-orange/30 bg-alliance-orange/10 text-alliance-orange text-xs font-semibold uppercase tracking-wider mb-6" data-hero-anim="badge">
              AI Act · Conformité dès août 2026
            </div>

            <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight" data-hero-anim="title">
              <span class="hero-line">L'IA au service de votre PME,</span>
              <span class="gradient-text hero-line">sans complexité technique</span>
            </h1>

            <p class="text-lg sm:text-xl text-white/70 max-w-2xl mb-10 leading-relaxed" data-hero-anim="lead">
              Alliance Digitale accompagne les PME avec salariés en Sarthe dans la conformité AI Act,
              l'adoption de l'IA générative et l'automatisation des tâches du quotidien.
            </p>

            <div class="flex flex-col sm:flex-row items-start gap-4" data-hero-anim="cta">
              <a href="/accompagnement/" class="btn-primary text-base px-8 py-4">Découvrir l'accompagnement</a>
              <a href="/contact/" class="btn-secondary text-base px-8 py-4">Prendre rendez-vous</a>
            </div>
            
            <div class="mt-12 flex flex-wrap items-center gap-6 text-sm text-white/65" data-hero-anim="stats">
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span data-count="23">23</span>&nbsp;sessions animées chez les clients
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span data-count="168">168</span>&nbsp;apprenants formés
              </span>
              <span class="flex items-center gap-2">
                <svg class="w-5 h-5 text-alliance-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                <span data-count="95" data-count-suffix=" %">95 %</span>&nbsp;de satisfaction
              </span>
            </div>
          </div>

          <div class="relative hidden lg:block" data-hero-parallax>
            <div class="absolute -inset-4 bg-gradient-to-br from-alliance-blue/20 to-alliance-orange/20 rounded-3xl blur-2xl"></div>
            <FiberFrame radius={16} class="relative block">
              <Image
                src={heroImage}
                alt="Formation IA et automatisation en Sarthe avec Alliance Digitale"
                widths={[480, 768, 1024, 1280]}
                sizes="(min-width: 1024px) 50vw, 100vw"
                formats={['avif', 'webp']}
                quality={75}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="relative rounded-2xl border border-white/10 shadow-2xl w-full object-cover"
              />
            </FiberFrame>
          </div>
        </div>
      </div>
    </section>

    <!-- PRÉSENTATION DES ACTIVITÉS -->
    <section class="py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center" data-reveal>
        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-white mb-6 leading-tight">
          Formation, automatisation et conformité IA<br class="hidden sm:block">
          pour les entreprises de Sarthe et Pays de la Loire
        </h2>
        <p class="text-white/70 text-lg leading-relaxed max-w-3xl mx-auto">
          Alliance Digitale accompagne les dirigeants et salariés de PME et TPE dans leur transformation numérique.
          Que vous cherchiez à <strong class="text-white">former vos équipes</strong>, <strong class="text-white">automatiser vos processus</strong>
          ou <strong class="text-white">vous mettre en conformité AI Act</strong>, nous avons la solution adaptée à votre taille et à votre métier.
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- GROUPE D'ONGLETS 1 : Accompagnement PME / Accompagnement TPE -->
    <!-- ============================================================ -->
    <section class="pb-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <!-- Titre du groupe -->
        <div class="text-center mb-6">
          <p class="text-sky-400 text-sm font-bold uppercase tracking-widest mb-2">Accompagnement</p>
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-white">Choisissez votre profil</h2>
        </div>

        <!-- Barre d'onglets -->
        <div class="tab-buttons" id="tabs-accompagnement">
          <button class="tab-btn active" data-group="accompagnement" data-tab="pme" onclick="switchTabGroup('accompagnement', 'pme')">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21h6"/></svg>
            Accompagnement PME
          </button>
          <button class="tab-btn" data-group="accompagnement" data-tab="tpe" onclick="switchTabGroup('accompagnement', 'tpe')">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.95-8.95a1.5 1.5 0 012.1 0L21.75 12M3 12v7.5A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 19.5V12"/></svg>
            Accompagnement TPE
          </button>
        </div>

        <!-- Contenu PME -->
        <div class="tab-content active" data-group="accompagnement" id="tab-accompagnement-pme">
          <div class="tab-panel tab-panel--pme">
            <div class="grid lg:grid-cols-2 gap-10 items-start">
              <div>
                <div class="flex items-center gap-2 mb-4">
                  <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21h6"/></svg>
                  <h3 class="font-display text-2xl sm:text-3xl font-bold text-white">
                    Accompagnement PME
                  </h3>
                </div>

                <p class="text-white/80 text-base mb-6 leading-relaxed">
                  Vous dirigez une PME avec salariés en Sarthe ? Nous vous accompagnons de l'audit initial au déploiement opérationnel.
                  Notre programme en 3 étapes transforme l'IA d'un sujet abstrait en un levier concret de productivité pour votre entreprise.
                </p>

                <ul class="space-y-3 mb-8">
                  <li class="flex items-start gap-3 text-white/80">
                    <span class="w-7 h-7 rounded-full bg-sky-500/20 text-sky-400 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
                    <div>
                      <strong class="text-white">Audit de vos processus</strong>
                      <p class="text-sm text-white/60">Nous analysons vos usages, identifions les tâches répétitives et les cas d'usage IA prioritaires.</p>
                    </div>
                  </li>
                  <li class="flex items-start gap-3 text-white/80">
                    <span class="w-7 h-7 rounded-full bg-sky-500/20 text-sky-400 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
                    <div>
                      <strong class="text-white">Formation collective de vos salariés</strong>
                      <p class="text-sm text-white/60">Sessions pratiques adaptées à votre métier, éligibles aux financements OPCO.</p>
                    </div>
                  </li>
                  <li class="flex items-start gap-3 text-white/80">
                    <span class="w-7 h-7 rounded-full bg-sky-500/20 text-sky-400 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
                    <div>
                      <strong class="text-white">Automatisation mesurable</strong>
                      <p class="text-sm text-white/60">Mise en place d'un premier workflow automatisé avec des résultats chiffrables en quelques semaines.</p>
                    </div>
                  </li>
                </ul>

                <a href="/accompagnement/" class="btn-primary inline-flex items-center gap-2">
                  Voir l'offre d'accompagnement
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
              </div>

              <div class="space-y-4">
                <div class="relief-panel p-6">
                  <blockquote class="text-lg text-white/90 italic leading-relaxed mb-4">
                    « Nous avons gagné l'équivalent d'une demi-journée par semaine sur la rédaction de nos comptes rendus. »
                  </blockquote>
                  <p class="text-sm text-white/60">PME industrielle, 25 salariés — étude de cas anonymisée</p>
                </div>

                <!-- Mini études de cas -->
                {heroStudies.length > 0 && (
                  <div class="space-y-3">
                    <p class="text-xs font-semibold uppercase tracking-widest text-sky-400/80">Réalisations</p>
                    {heroStudies.slice(0, 2).map((study) => (
                      <a href="/accompagnement/" class="block p-4 rounded-lg border border-sky-500/20 bg-sky-900/20 hover:bg-sky-900/30 transition">
                        <h4 class="font-semibold text-white text-sm mb-1">{study.title}</h4>
                        <p class="text-xs text-white/60">{study.sector}</p>
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </div>

            <!-- Secteurs PME -->
            <div class="mt-10 pt-8 border-t border-sky-500/20">
              <p class="text-sm font-semibold uppercase tracking-widest text-sky-400/80 mb-4">Secteurs accompagnés</p>
              <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
                {[
                  { emoji: "🔧", label: "Artisans BTP", hours: "18h/mois" },
                  { emoji: "🩺", label: "Santé", hours: "21h/mois" },
                  { emoji: "🛍️", label: "Commerces", hours: "24h/mois" },
                  { emoji: "🏠", label: "Immobilier", hours: "24h/mois" },
                  { emoji: "⚖️", label: "Libérales", hours: "23h/mois" },
                ].map((sec) => (
                  <a href="/automatisations/" class="group flex flex-col items-center gap-1.5 p-3 rounded-xl border border-sky-500/15 bg-sky-900/15 hover:bg-sky-900/30 hover:border-sky-500/30 transition text-center">
                    <span class="text-2xl">{sec.emoji}</span>
                    <span class="text-xs font-semibold text-white/80 group-hover:text-white transition-colors">{sec.label}</span>
                    <span class="text-xs text-sky-400 font-bold">{sec.hours}</span>
                  </a>
                ))}
              </div>
              <div class="text-center mt-4">
                <a href="/automatisations/" class="text-sm text-sky-400 hover:text-sky-300 transition-colors inline-flex items-center gap-1">
                  Voir tous les secteurs et calculer votre gain
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contenu TPE -->
        <div class="tab-content" data-group="accompagnement" id="tab-accompagnement-tpe">
          <div class="tab-panel tab-panel--tpe">
            <div class="grid lg:grid-cols-2 gap-10 items-start">
              <div>
                <div class="flex items-center gap-2 mb-4">
                  <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.95-8.95a1.5 1.5 0 012.1 0L21.75 12M3 12v7.5A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 19.5V12"/></svg>
                  <h3 class="font-display text-2xl sm:text-3xl font-bold text-white">
                    Accompagnement TPE
                  </h3>
                </div>

                <p class="text-white/80 text-base mb-6 leading-relaxed">
                  Vous êtes auto-entrepreneur, artisan, ou dirigez une petite entreprise de moins de 10 salariés ?
                  Notre offre TPE est conçue pour vous : un <strong class="text-white">site vitrine professionnel</strong> optimisé pour votre métier,
                  couplé à une <strong class="text-white">stratégie d'automatisation adaptée</strong> à vos moyens.
                </p>

                <p class="text-white/70 text-sm mb-6 leading-relaxed">
                  Fini les sites génériques qui ne convertissent pas. Nous créons pour vous un site qui reflète votre savoir-faire,
                  qui apparaît quand vos clients vous cherchent, et qui intègre les bons outils pour vous faire gagner du temps au quotidien.
                </p>

                <ul class="space-y-3 mb-8">
                  <li class="flex items-start gap-3 text-white/80">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span><strong class="text-white">Site professionnel sur-mesure</strong> adapté à votre métier et votre territoire</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/80">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span><strong class="text-white">SEO local</strong> pour apparaître quand on vous cherche</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/80">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span><strong class="text-white">Prise de rendez-vous</strong> et devis en ligne intégrés</span>
                  </li>
                  <li class="flex items-start gap-3 text-white/80">
                    <svg class="w-5 h-5 text-emerald-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    <span><strong class="text-white">Automatisations</strong> : relances, factures, suivi client</span>
                  </li>
                </ul>

                <a href="/contact/" class="btn-primary inline-flex items-center gap-2" style="background: linear-gradient(135deg, #059669, #047857);">
                  Demander un devis pour ma TPE
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                </a>
              </div>

              <!-- Démos TPE -->
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-emerald-400/80 mb-4">Exemples de sites TPE</p>
                <div class="grid grid-cols-2 gap-3">
                  {tpeDemos.map((demo) => (
                    <a
                      href={demo.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group flex flex-col items-center gap-2 p-4 rounded-xl border border-emerald-500/20 bg-emerald-900/20 hover:bg-emerald-900/30 hover:border-emerald-500/40 transition text-center"
                    >
                      <span class="text-3xl">{demo.emoji}</span>
                      <span class="text-sm font-semibold text-white group-hover:text-emerald-300 transition-colors">{demo.label}</span>
                      <span class="text-xs text-white/50">{demo.desc}</span>
                      <span class="text-[10px] text-emerald-400/70 flex items-center gap-1">
                        Voir la démo
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                      </span>
                    </a>
                  ))}
                </div>

                <div class="mt-4 p-4 rounded-lg border border-emerald-500/15 bg-emerald-900/15">
                  <p class="text-xs text-white/60 leading-relaxed">
                    💡 Chaque site est adapté au métier et aux besoins du client. Ces exemples illustrent le type de résultats que nous obtenons pour les TPE et auto-entrepreneurs.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- GROUPE D'ONGLETS 2 : Formations / Automatisations / Challenge -->
    <!-- ============================================================ -->
    <section class="py-16 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <!-- Titre du groupe -->
        <div class="text-center mb-6">
          <p class="text-red-400 text-sm font-bold uppercase tracking-widest mb-2">Services</p>
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-white">Nos services</h2>
        </div>

        <!-- Barre d'onglets -->
        <div class="tab-buttons" id="tabs-services">
          <button class="tab-btn active" data-group="services" data-tab="formations" onclick="switchTabGroup('services', 'formations')">
