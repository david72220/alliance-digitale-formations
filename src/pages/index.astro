  <Footer />

  <script is:inline>
    function switchTabGroup(group, tabId) {
      // Désactiver tous les onglets du même groupe
      document.querySelectorAll('.tab-btn[data-group="' + group + '"]').forEach(function(btn) {
        btn.classList.remove('active');
      });
      document.querySelectorAll('.tab-content[data-group="' + group + '"]').forEach(function(panel) {
        panel.classList.remove('active');
      });
      
      // Activer l'onglet sélectionné
      document.querySelector('.tab-btn[data-group="' + group + '"][data-tab="' + tabId + '"]').classList.add('active');
      document.getElementById('tab-' + group + '-' + tabId).classList.add('active');
    }
  </script>
