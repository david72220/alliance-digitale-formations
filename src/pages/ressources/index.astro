---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getResources } from '../../lib/notion.ts';

const resources = await getResources();

// Groupement par module
const grouped = resources.reduce((acc, resource) => {
  const mod = resource.module || 'Autres';
  if (!acc[mod]) acc[mod] = [];
  acc[mod].push(resource);
  return acc;
}, {} as Record<string, typeof resources>);

const modules = Object.keys(grouped).sort();

const pageDescription = "Cours simples, guides et ressources gratuites sur l'IA générative, la sécurité des données et l'automatisation pour les PME et auto-entrepreneurs.";
---

<Layout
  title="Ressources gratuites — Alliance Digitale"
  description={pageDescription}
>
  <Header />

  <main class="flex-1">
    <section class="pt-36 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-alliance-blue text-sm font-bold uppercase tracking-widest mb-3">Ressources</p>
          
          <h1 class="font-serif text-4xl sm:text-5xl font-bold text-white mb-6">Guides et ressources gratuites</h1>
          
          <p class="text-white/60 max-w-2xl mx-auto">
            Cours pratiques classés par module pour démarrer avec l'IA, sécuriser vos données
            et identifier vos premiers cas d'automatisation en PME.
          </p>
        </div>

        {modules.length > 0 ? (
          <div class="space-y-16">
            {modules.map((module) => (
              <div key={module}>
                <h2 class="font-display text-2xl font-bold text-white mb-6 border-b border-white/10 pb-3" data-reveal>
                  {module}
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                  {grouped[module].map((resource, i) => (
                    <a
                      href={`/ressources/${resource.slug}/`}
                      data-reveal
                      data-reveal-delay={String(i * 0.06)}
                      class="group block rounded-xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] transition overflow-hidden"
                    >
                      {resource.photo && (
                        <div class="h-40 overflow-hidden">
                          <img src={resource.photo} alt={resource.title} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        </div>
                      )}
                      <div class="p-6">
                        <span class="inline-block px-2 py-0.5 rounded bg-alliance-blue/10 text-alliance-blue text-xs font-semibold mb-3">
                          {resource.module}
                        </span>
                        <h3 class="font-display text-xl font-bold text-white mb-2">{resource.title}</h3>
                        <p class="text-white/60">{resource.description}</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-20 border border-white/10 rounded-2xl bg-white/[0.02]">
            <p class="text-white/60">Les premières ressources seront publiées prochainement dans Notion.</p>
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
