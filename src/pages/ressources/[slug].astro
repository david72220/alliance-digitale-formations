---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getResources, type Resource } from '../../lib/notion.ts';
import { estimateReadTime } from '../../lib/markdown.ts';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const notionResources = await getResources();

  // Fallback : catalogue public/ressources/resources.json si Notion échoue
  let localResources: Resource[] = [];
  try {
    const localModule = await import('../../../public/ressources/resources.json', {
      assert: { type: 'json' },
    });
    localResources = Array.isArray(localModule.default) ? localModule.default : [];
  } catch (err) {
    console.warn('Impossible de charger public/ressources/resources.json:', (err as Error).message);
  }

  const all = new Map<string, Resource>();
  [...localResources, ...notionResources].forEach((r) => {
    const slug = (r.slug || '').trim();
    if (!slug || slug.includes(' ')) return;
    all.set(slug, { ...all.get(slug), ...r, slug });
  });

  return Array.from(all.entries()).map(([slug, resource]) => {
    let dataJson: any = null;
    if (resource.contentJson) {
      try {
        const filePath = path.join(process.cwd(), 'public', resource.contentJson.replace(/^\//, ''));
        dataJson = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
      } catch (err) {
        console.warn(`Impossible de charger ${resource.contentJson}:`, (err as Error).message);
      }
    }

    return {
      params: { slug },
      props: {
        resource,
        contentHtml: dataJson?.contentHtml || '',
        exerciseHtml: dataJson?.exerciseHtml || '',
        title: dataJson?.title || resource.title,
        description: dataJson?.description || resource.description,
        moduleName: dataJson?.module || resource.module || 'Ressource',
        solutionUrl: dataJson?.solutionUrl || resource.solutionUrl,
        photoUrl: dataJson?.photo || resource.photo || null,
      },
    };
  });
}

const { resource, contentHtml, exerciseHtml, title, description, moduleName, solutionUrl, photoUrl } = Astro.props;

const readTime = estimateReadTime(contentHtml);
const siteUrl = Astro.site ? Astro.site.toString() : 'https://alliance-digitale-formations.vercel.app';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Ressources', item: `${siteUrl}/ressources/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LearningResource',
  name: title,
  description,
  learningResourceType: 'article',
  educationalLevel: 'Beginner to intermediate',
  inLanguage: 'fr-FR',
  isPartOf: {
    '@type': 'Course',
    name: `Module ${moduleName}`,
    provider: { '@type': 'Organization', name: 'Alliance Digitale' },
    image: photoUrl ? { '@type': 'ImageObject', url: photoUrl } : undefined,
  },
};
---

<Layout title={`${title} — Alliance Digitale`} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(courseJsonLd)} />
    <link rel="canonical" href={`${siteUrl}/ressources/${resource.slug}/`} />
  </Fragment>

  <Header />

  <main class="flex-1">
    <section class="pt-36 pb-20 px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        {photoUrl && (
          <div class="mb-8 rounded-2xl overflow-hidden border border-white/10">
            <img src={photoUrl} alt={title} class="w-full h-64 sm:h-80 object-cover" />
          </div>
        )}

        <nav aria-label="Fil d'ariane" class="text-sm text-white/50 mb-6">
          <a href="/" class="hover:text-alliance-blue transition">Accueil</a>
          <span class="mx-2">/</span>
          <a href="/ressources/" class="hover:text-alliance-blue transition">Ressources</a>
          <span class="mx-2">/</span>
          <span class="text-white/80">{title}</span>
        </nav>

        <div class="mb-2">
          <span class="inline-block px-3 py-1 rounded-full bg-alliance-blue/10 text-alliance-blue text-xs font-bold uppercase tracking-wider">
            {moduleName}
          </span>
        </div>

        <h1 class="font-serif text-3xl sm:text-4xl font-bold text-white mb-4">{title}</h1>

        <p class="text-white/70 text-lg mb-4">{description}</p>

        {readTime > 0 && (
          <p class="text-sm text-white/50 mb-10">Temps de lecture : environ {readTime} min</p>
        )}

        {contentHtml ? (
          <article class="prose prose-invert prose-lg max-w-none mb-16">
            <Fragment set:html={contentHtml} />
          </article>
        ) : (
          <div class="text-center py-20 border border-white/10 rounded-2xl bg-white/[0.02] mb-16">
            <p class="text-white/60">Le contenu de cette ressource n'est pas disponible pour le moment.</p>
          </div>
        )}

        {exerciseHtml && (
          <div class="border-t border-white/10 pt-12 mb-16">
            <h2 class="font-display text-2xl font-bold text-white mb-6">Exercice pratique</h2>
            <div class="prose prose-invert max-w-none">
              <Fragment set:html={exerciseHtml} />
            </div>

            {solutionUrl && (
              <div class="mt-8">
                <a
                  href={solutionUrl}
                  download
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-alliance-blue text-white font-semibold hover:bg-alliance-blue/90 transition"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  Télécharger la solution (PDF)
                </a>
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
