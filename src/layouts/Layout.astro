---
import '../styles/global.css';
import ChatBotAD from '../components/ChatBotAD.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title: rawTitle, description: rawDesc = "Accompagnement et formations IA pour PME avec salariés en Sarthe.", image = "/og-image.png", noindex = false, jsonLd } = Astro.props;

// SEO length caps (Google SERP): ~60 chars title, ~155 chars description.
function truncate(s: string, max: number): string {
  const t = (s ?? '').replace(/\s+/g, ' ').trim();
  if (t.length <= max) return t;
  const cut = t.slice(0, max - 1);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > max * 0.6 ? cut.slice(0, lastSpace) : cut) + '…';
}
const title = truncate(rawTitle, 60);
const description = truncate(rawDesc, 155);

const canonical = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site!.toString().replace(/\/$/, '');

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Alliance Digitale",
  "url": siteUrl,
  "logo": `${siteUrl}/LOGO%20alliance-Digitale%20blanc.png`,
  "description": "Accompagnement IA et automatisation pour PME avec salariés en Sarthe.",
  "areaServed": { "@type": "AdministrativeArea", "name": "Sarthe" },
  "address": { "@type": "PostalAddress", "addressCountry": "FR", "addressRegion": "Pays de la Loire" }
};

const localBusinessLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}/#business`,
  "name": "Alliance Digitale",
  "description": "Accompagnement IA, automatisation et formations pour PME avec salariés en Sarthe. Audit IA, formation littératie IA, mise en place d'automatisations concrètes.",
  "url": siteUrl,
  "logo": `${siteUrl}/LOGO%20alliance-Digitale%20blanc.png`,
  "image": `${siteUrl}/og-image.png`,
  "telephone": "+33-2-43-00-00-00",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Le Mans",
    "addressRegion": "Sarthe",
    "addressCountry": "FR",
    "postalCode": "72000"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 48.0061,
    "longitude": 0.1996
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Sarthe" },
    { "@type": "AdministrativeArea", "name": "Pays de la Loire" }
  ],
  "priceRange": "€€",
  "openingHours": "Mo-Fr 09:00-18:00",
  "sameAs": [
    "https://www.linkedin.com/company/alliance-digitale-sarthe"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services Alliance Digitale",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Audit IA express",
          "description": "Identification de vos cas d'usage IA prioritaires, évaluation de la conformité AI Act et estimation du gain de productivité."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Formation collective IA",
          "description": "Session de littératie IA pour vos salariés : usages responsables, prompts efficaces, sécurité des données."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Automatisation ciblée",
          "description": "Mise en place d'un premier workflow automatisé : documents, emails, reporting ou tout processus répétitif."
        }
      }
    ]
  }
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Alliance Digitale",
  "url": siteUrl
};

const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allLd = [organizationLd, localBusinessLd, websiteLd, ...extraLd];

// Analytics + SEO verification (env-driven so no rebuild on token change).
const gscToken = import.meta.env.GSC_VERIFICATION;
const bingToken = import.meta.env.BING_VERIFICATION;
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
---

<!DOCTYPE html>
<html lang="fr-FR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {!noindex && <meta name="robots" content="index, follow" />}
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical.toString()} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site).toString()} />
  <meta property="og:url" content={canonical.toString()} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {gscToken && <meta name="google-site-verification" content={gscToken} />}
  {bingToken && <meta name="msvalidate.01" content={bingToken} />}
  {plausibleDomain && (
    <script is:inline defer data-domain={plausibleDomain} src="https://plausible.io/js/script.outbound-links.js"></script>
  )}
  {allLd.map((ld) => (
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
  ))}
  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col bg-alliance-dark text-white">
  <slot />

  <script>
    import '@fontsource/inter/300.css';
    import '@fontsource/inter/400.css';
    import '@fontsource/inter/500.css';
    import '@fontsource/inter/600.css';
    import '@fontsource/inter/700.css';
    import '@fontsource/inter/800.css';
    import '@fontsource/playfair-display/600.css';
    import '@fontsource/playfair-display/700.css';
    import '@fontsource/space-grotesk/400.css';
    import '@fontsource/space-grotesk/500.css';
    import '@fontsource/space-grotesk/600.css';
    import '@fontsource/space-grotesk/700.css';
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduce) {
      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.1,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);
    }

    const reveal = (els: Element[]) => {
      els.forEach((el, i) => {
        const delay = parseFloat((el as HTMLElement).dataset.revealDelay ?? '0');
        gsap.fromTo(
          el,
          { opacity: 0, y: 32 },
          {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: 'power3.out',
            delay,
            scrollTrigger: { trigger: el, start: 'top 85%', once: true },
          }
        );
      });
    };

    const items = Array.from(document.querySelectorAll('[data-reveal]'));
    if (reduce) {
      items.forEach((el) => ((el as HTMLElement).style.opacity = '1'));
    } else {
      reveal(items);
    }

    // Hero intro timeline
    const heroEls = document.querySelectorAll('[data-hero-anim]');
    if (heroEls.length && !reduce) {
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      heroEls.forEach((el) => {
        tl.fromTo(
          el,
          { opacity: 0, y: 24 },
          { opacity: 1, y: 0, duration: 0.8 },
          '-=0.55'
        );
      });
    } else if (reduce) {
      heroEls.forEach((el) => ((el as HTMLElement).style.opacity = '1'));
    }

    // Hero image parallax
    const parallax = document.querySelector('[data-hero-parallax]');
    if (parallax && !reduce) {
      gsap.to(parallax, {
        y: -60,
        ease: 'none',
        scrollTrigger: {
          trigger: parallax,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      });
    }

    // Counters
    const counters = document.querySelectorAll<HTMLElement>('[data-count]');
    counters.forEach((el) => {
      const target = parseInt(el.dataset.count ?? '0', 10);
      const suffix = el.dataset.countSuffix ?? '';
      if (reduce) {
        el.textContent = `${target}${suffix}`;
        return;
      }
      const obj = { val: 0 };
      gsap.to(obj, {
        val: target,
        duration: 1.6,
        ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        onUpdate: () => {
          el.textContent = `${Math.round(obj.val)}${suffix}`;
        },
      });
    });
  </script>
  <ChatBotAD />
</body>
</html>
